{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug FEL2",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/fel2.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
      "preLaunchTask": "build",
      "miDebuggerArgs": "",
      "logging": {
        "moduleLoad": false,
        "trace": true,
        "traceResponse": true
      },
      "windows": {
        "MIMode": "gdb",
        "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe"
      },
      "osx": {
        "MIMode": "lldb",
        "miDebuggerPath": "/usr/bin/lldb"
      },
      "linux": {
        "MIMode": "gdb",
        "miDebuggerPath": "/usr/bin/gdb"
      }
    }
  ]
}
